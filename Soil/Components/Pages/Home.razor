@page "/"
@using Soil.Models
@using Soil.Services.Interface
@inject ISoilService SoilService
@rendermode InteractiveServer
@implements IDisposable 


<PageTitle> Soil Mointor</PageTitle>

<div class="container-main">
    <h1>Soil Status</h1>
    
    <div class="Box-tl">
        <h2> Seneste Måling - Satemin </h2>
        @if (indlæser)
        {
            <p>Henter data...</p>
        }
        else
        {
            <div class="maaling-grid">
                @if (overfladeMaaling != null)
                {
                    <div class="maalingIndhold">
                        <span class="fugtighed-tal">@overfladeMaaling.Depth.ToString("0.0") cm</span>
                        <span class="fugtighedTal">@overfladeMaaling.MoistureLevel.ToString("0.000") m³/m³</span>
                        <p class="tid-tekst">Målt den: @overfladeMaaling.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</p>
                    </div>
                }

                @if (undergrundMaaling != null)
                {
                    <div class="maalingIndhold">
                        <span class="fugtighed-tal">@undergrundMaaling.Depth.ToString("0.0") cm</span>
                        <span class="fugtighedTal">@undergrundMaaling.MoistureLevel.ToString("0.000") m³/m³</span>
                        <p class="tid-tekst">Målt den: @undergrundMaaling.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</p>
                    </div>
                }
            </div>
        }
    </div>
    
    
    <div class="Box-tr">
        <h2> Data historik </h2>
        @if (historik.Count == 0)
        {
            <p>ingen historik endnu</p>
        }
        else
        {
            <table>
                <thead>
                <tr>
                    <th>Tidspunkt</th>
                    <th>Fugtighed</th>
                    <th>Dybde</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var maaling in historik)

                {
                    <tr>
                        <td>@maaling.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td>@maaling.MoistureLevel.ToString("0.000") m³/m³</td>
                        <td>@maaling.Depth.ToString("0") cm</td>
                    </tr>

                }

                </tbody>

            </table>
        }
       
    </div>
    
    <div class="Box-bl">
        <h2> Graf over data point </h2>
        @if (!indlæser)
        {
            <PlotlyChart @bind-Config="config"
                         @bind-Layout="layout"
                         @bind-Data="grafData"></PlotlyChart>
            
        }
    </div>
    
    
    <div class="Box-br">

        <h2>For tørt - Alarm</h2>

        @if (alarmAktiv)

        {

            <div class="alarm-boks">

                <p>⚠️ Fugtighed under grænseværdi!</p>

            </div>

        }

        @if (beskederSendt)  

        {

            <p style="color: green; font-weight: bold; text-align: center;">✅ Besked sendt til operatør!</p>

        }

        <button @onclick="SendNotifikation">Send operatør til vande</button>

    </div>
    

</div>

@code {

    private SoilMoistureReading? overfladeMaaling ;
    private SoilMoistureReading? undergrundMaaling ;
    private List<SoilMoistureReading> historik = new();
    private Plotly.Blazor.Config config = new();
    private IList<ITrace> grafData = new List<ITrace>();
    private PeriodicTimer? timer;
    private const double Grænseværdi = 0.100;
    private bool alarmAktiv=false; 
    private bool beskederSendt = false; 
    
    private Plotly.Blazor.Layout layout = new()
    {
        Height = 300,
        AutoSize = true,
        Margin = new() { L = 50, R = 20, T = 20, B = 80 }, 
        XAxis = new List<XAxis>
        {
            new XAxis
            {
                TickAngle = -45  
            }
        }
    };

    private void BuildGraf()
    {
        var overfladePunkter = historik
            .Where(r => r.Depth == 1).OrderBy(r => r.Timestamp).ToList();
        
        var undergrudPunkter = historik
            .Where(r => r.Depth == 54).OrderBy(r => r.Timestamp).ToList();

        grafData = new List<ITrace>
        {
            new Scatter
            {
                Name = "Overflade (1cm)",
                X = overfladePunkter.Select(r => (object)r.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")).ToList(),
                Y = overfladePunkter.Select(r => (object)r.MoistureLevel).ToList(),
                Mode = Plotly.Blazor.Traces.ScatterLib.ModeFlag.Lines

            },
            new Scatter
            {
                Name = "Undergrund (54cm)",
                X = undergrudPunkter.Select(r => (object)r.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")).ToList(),
                Y = undergrudPunkter.Select(r => (object)r.MoistureLevel).ToList(),
                Mode = Plotly.Blazor.Traces.ScatterLib.ModeFlag.Lines
            }

        };

    }
    

    private async Task IndlæsData()
    {
        await SoilService.GemMålingAsync();
        overfladeMaaling = await SoilService.GetLatestByDepthAsync(1);
        undergrundMaaling = await SoilService.GetLatestByDepthAsync(54);
        historik = await SoilService.GetHistoryAsync();
        BuildGraf();

        if (overfladeMaaling != null && overfladeMaaling.MoistureLevel < Grænseværdi)
        {
            Console.WriteLine($"ALARM: Overflade fugtighed er under grænseværdi! Værdi: {overfladeMaaling.MoistureLevel}");
            alarmAktiv = true;
        }
        else
        {
            alarmAktiv = false;
        }

        indlæser = false;

    }
    private void SendNotifikation() 
    {
        Console.WriteLine("NOTIFIKATION: Operatør er blevet kontaktet for at vande.");
        beskederSendt = true;
    }


    private bool indlæser = true;

    protected override async Task OnInitializedAsync()
    {
            await IndlæsData();
            timer = new PeriodicTimer(TimeSpan.FromMinutes(60));
            _ = Task.Run(async () =>
            {
                while (await timer.WaitForNextTickAsync())
                {
                    await IndlæsData();
                    await InvokeAsync(StateHasChanged);
                }
            });

    }

    public void Dispose()
    {
        timer.Dispose();
    }
    
    

}